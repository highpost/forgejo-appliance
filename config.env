FORGEJO_VM="forgejo-appliance"
FORGEJO_YAML="forgejo-appliance.yml"
TS_CERT_CACHE="tsbridge-cert-cache"
TS_OAUTH_SECRET_KEY="tsbridge-oauth-secret"

TS_HOSTNAME=${UPDATE_ME:?"FATAL: provide a valid TS_HOSTNAME in config.env"}
TS_OAUTH_CLIENT_ID=${UPDATE_ME:?"FATAL: provide a valid TS_OAUTH_CLIENT_ID in config.env"}
TS_TAILNET=${UPDATE_ME:?"FATAL: provide a valid TS_TAILNET in config.env"}
